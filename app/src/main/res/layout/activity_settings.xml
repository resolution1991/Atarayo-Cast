<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:background="@color/background"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:navigationIconTint="@color/on_surface"
        app:title="@string/settings_title"
        app:titleCentered="true"
        app:titleTextColor="@color/on_surface" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingsToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="600dp">

            <LinearLayout
                android:id="@+id/settingsContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_max="720dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_subtitle"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/serviceRunningBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface_container_high"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/status_warning"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_service_running_title"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvServiceRunningHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/settings_service_running_hint"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStopServiceFromSettings"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_gravity="end"
                            android:layout_marginTop="8dp"
                            android:text="@string/settings_stop_to_edit"
                            android:textColor="@color/status_warning"
                            app:icon="@drawable/ic_stop_24"
                            app:iconTint="@color/status_warning" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_section_receiver"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowDeviceName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/device_name_label"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/tvDeviceName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/device_name_default"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="12dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="@color/on_surface_variant" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowAdaptiveRes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_adaptive_resolution"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/settings_adaptive_resolution_desc"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/swAdaptiveRes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowResolution"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_resolution"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/tvResolution"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/settings_resolution_auto"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="12dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chevron_right_24"
                                app:tint="@color/on_surface_variant" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_section_quality"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowH265"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="82dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_h265"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/settings_h265_desc"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/swH265"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowForceH265"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="88dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_force_h265"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/settings_force_h265_desc"
                                    android:textColor="@color/status_warning"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/swForceH265"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_section_playback"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowKeepScreenOn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_keep_screen_on"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/settings_keep_screen_on_desc"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/swKeepScreenOn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="18dp" android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowFullscreenDefault"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="82dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_fullscreen_default" android:textColor="@color/on_surface" android:textSize="16sp" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_fullscreen_default_desc" android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/swFullscreenDefault" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="18dp" android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowPip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_pip" android:textColor="@color/on_surface" android:textSize="16sp" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_pip_desc" android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/swPip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_section_security"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowPin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_pin" android:textColor="@color/on_surface" android:textSize="16sp" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_pin_desc" android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/swPin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="18dp" android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/rowBootStart"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:minHeight="80dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_boot" android:textColor="@color/on_surface" android:textSize="16sp" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_boot_desc" android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/swBootStart" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp"
                    android:text="@string/settings_section_developer"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/rowDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="80dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_debug" android:textColor="@color/on_surface" android:textSize="16sp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/settings_debug_desc" android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/swDebug" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
