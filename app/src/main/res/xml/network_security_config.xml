<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- DLNA controllers usually provide media URLs as plain HTTP LAN IPs
         such as http://192.168.x.x:port/file.mp4. Network Security Config
         cannot express private IP ranges as domains, so cleartext must be
         allowed at base level for the renderer to fetch pushed media. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
